        { "subnet": "10.1.0.0/16", "description": "Corporate workstation range" }
      ],
      "children": ["Servers"],
      "parents": []
    },
    "Servers": {
      "domain": "Default",
      "is_shared": false,
      "description": "Internal server segment",
