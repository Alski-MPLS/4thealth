        { "subnet": "10.0.0.0/24", "description": "DMZ server range" }
      ],
      "children": [],
      "parents": []
    },
    "Corporate": {
      "domain": "Default",
      "is_shared": false,
      "description": "Corporate LAN — end-user workstations",
