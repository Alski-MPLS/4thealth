# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# ── Core ──────────────────────────────────────────────────────────────────────

# Generate with: python manage_users.py secret
SECRET_KEY=

# auto = set Secure cookie flag when TLS certs are present (recommended)
# true = always set; false = never set
COOKIE_SECURE=auto

# Listening port — auto-selects 5443 when TLS certs are present, 5000 otherwise
# PORT=5000

# TLS certificate paths (relative to project root)
# SSL_CERT=certs/cert.pem
# SSL_KEY=certs/key.pem

# ── FortiManager ──────────────────────────────────────────────────────────────

FMG_PRIMARY_HOST=

# Bearer token (preferred) — generate on FMG: System Settings → Administrators → API token
FMG_API_TOKEN=

# Username/password fallback (used only when FMG_API_TOKEN is not set)
# FMG_USERNAME=
# FMG_PASSWORD=

# Set true to validate the FortiManager TLS certificate in production
FMG_VERIFY_SSL=false

# FMG_TIMEOUT=30

# ── Health thresholds ─────────────────────────────────────────────────────────

CPU_WARN=70
CPU_CRIT=90
MEM_WARN=75
MEM_CRIT=90

# ── Background job schedule ───────────────────────────────────────────────────

# Hour (0–23) and minute the nightly managed-network summary fires (server local time)
SUMMARY_REFRESH_HOUR=1
SUMMARY_REFRESH_MINUTE=0

# ── Map (Beta) ────────────────────────────────────────────────────────────────

# How often to re-fetch device locations from FortiManager (hours; default 24)
# MAP_CACHE_INTERVAL_HOURS=24

# ── Active Directory / LDAP (optional) ────────────────────────────────────────

# AD_ENABLED=false
# AD_SERVER=ldaps://dc.yourdomain.com:636
# AD_DOMAIN=YOURDOMAIN
# AD_BASE_DN=DC=yourdomain,DC=com
# AD_BIND_USER=CN=svc_4thealth,OU=Service Accounts,DC=yourdomain,DC=com
# AD_BIND_PASSWORD=
# AD_USER_SEARCH=OU=Users,DC=yourdomain,DC=com
# AD_GROUP_ADMIN=CN=4THealth-Admins,OU=Security Groups,DC=yourdomain,DC=com
# AD_GROUP_VIEWER=CN=4THealth-Viewers,OU=Security Groups,DC=yourdomain,DC=com
# AD_VERIFY_SSL=false

# ── FortiAuthenticator RADIUS (optional) ──────────────────────────────────────

# RADIUS_ENABLED=false
# RADIUS_HOST=
# RADIUS_PORT=1812
# RADIUS_SECRET=
# RADIUS_AUTH_METHOD=pap
# RADIUS_TIMEOUT=10
# RADIUS_GROUP_ADMIN=4THealth-Admins
# RADIUS_GROUP_VIEWER=4THealth-Viewers
