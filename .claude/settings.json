{
  "permissions": {
    "deny": [
      "Read(.env*)"
    ],
    "allow": [
      "Read(.env.example)",
      "Bash(uv run pytest *)",
      "Bash(uv run pytest)",
      "Bash(uv run ruff check *)",
      "Bash(uv run ruff format --check *)",
      "Bash(uv sync)",
      "Bash(SECRET_KEY=* uv run pytest *)"
    ]
  }
}
