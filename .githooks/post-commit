#!/bin/sh
# Keep the local graphify-out/ knowledge graph in sync with committed code.
# graphify-out/ is gitignored (local build artifact) so this never needs to
# be committed itself — it just needs to stay fresh for AI assistant queries.
#
# One-time setup per clone: git config core.hooksPath .githooks

if command -v graphify >/dev/null 2>&1 && [ -d graphify-out ]; then
  graphify update . >/dev/null 2>&1 &
fi
